# Google Veo
GOOGLE_API_KEY=

# Frontend URLs (for CORS)
APP_URL=http://localhost:3000
ADMIN_URL=http://localhost:3002

# WebSocket CORS (comma-separated origins, defaults to * if not set)
WS_CORS_ORIGIN=http://localhost:3000,http://localhost:3002

# API
NEXT_PUBLIC_API_URL=http://localhost:4000
