# ========== Database ==========
DB_USER=vsaas
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=vsaas

# ========== Redis ==========
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ========== Auth ==========
JWT_SECRET=CHANGE_ME_JWT_SECRET_AT_LEAST_32_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_AT_LEAST_32_CHARS
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=7d

# ========== Aliyun OSS ==========
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
OSS_BUCKET=vsaas-media
OSS_REGION=oss-cn-shanghai
CDN_DOMAIN=

# ========== Aliyun IMS ==========
ALIYUN_IMS_REGION=cn-shanghai
IMS_CALLBACK_TOKEN=CHANGE_ME_CALLBACK_TOKEN

# ========== Optional AI / Provider Keys (missing keys disable related features, but API can still boot) ==========
# Required for Qwen / Wan / Voice, and also used as the fallback for LLM_API_KEY
DASHSCOPE_API_KEY=
GROK_API_KEY=
OPENAI_API_KEY=
VOLCENGINE_API_KEY=
# Optional explicit LLM key override (falls back to DASHSCOPE_API_KEY when empty)
LLM_API_KEY=
LLM_API_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
LLM_VISION_MODEL=qwen-vl-plus
# Required for Veo, and also used as the fallback for GOOGLE_IMAGEN_API_KEY
GOOGLE_API_KEY=
# Optional explicit Imagen key override
GOOGLE_IMAGEN_API_KEY=

# ========== URLs ==========
# 你的域名（替换为实际域名）
NEXT_PUBLIC_API_URL=https://your-domain.com
API_BASE_URL=https://your-domain.com
APP_URL=https://your-domain.com
ADMIN_URL=https://admin.your-domain.com

# CORS（逗号分隔）
CORS_ORIGIN=https://your-domain.com,https://admin.your-domain.com
WS_CORS_ORIGIN=https://your-domain.com,https://admin.your-domain.com

# ========== Ports ==========
HTTP_PORT=80
