generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== Enums ====================

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum JobType {
  // Active types
  TEXT_TO_IMAGE
  IMAGE_TO_IMAGE
  TEXT_TO_VIDEO
  IMAGE_TO_VIDEO
  VOICE_CLONE
  DIGITAL_HUMAN_VIDEO
  BATCH_COMPOSE
  STYLE_COPY
  TEXT_EDIT
  HANDHELD_PRODUCT
  DH_BATCH_V2
  MULTI_FUSION
  VIRTUAL_TRYON
  INPAINT
  IMAGE_EDIT
  STORYBOARD
  // Legacy types (kept for backwards compatibility)
  IMAGE
  VIDEO
  TTS
  DIGITAL_HUMAN
  VIDEO_EDIT
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum MaterialType {
  IMAGE
  VIDEO
  AUDIO
  TEMPLATE
  BACKGROUND
  STICKER
  AVATAR
}

enum AssetType {
  IMAGE
  VIDEO
  AUDIO
  VOICE_SAMPLE
}

enum VoiceCloneStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum TransactionType {
  PURCHASE
  USAGE
  REFUND
  ADMIN_ADJUSTMENT
  BONUS
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum ComposeStatus {
  DRAFT
  SUBMITTED
  PROCESSING
  COMPLETED
  PARTIALLY_COMPLETED
  FAILED
}

// ==================== Users & Auth ====================

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  passwordHash  String     @map("password_hash")
  displayName   String?    @map("display_name")
  avatar        String?
  role          UserRole   @default(USER)
  status        UserStatus @default(ACTIVE)
  creditBalance Int        @default(0) @map("credit_balance")
  lastLoginAt   DateTime?  @map("last_login_at")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  oauthAccounts      OAuthAccount[]
  generations        Generation[]
  voices             Voice[]
  materials          Material[]
  scripts            Script[]
  creditTransactions CreditTransaction[]
  orders             Order[]
  favorites          Favorite[]
  avatars            DigitalHumanAvatar[]
  composeProjects    ComposeProject[]
  assets             Asset[]
  auditLogsPerformed AuditLog[] @relation("performer")
  auditLogsTargeted  AuditLog[] @relation("target")

  @@map("users")
}

model OAuthAccount {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  provider   String
  providerId String   @map("provider_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@map("oauth_accounts")
}

// ==================== Credits & Billing ====================

model CreditTransaction {
  id           String          @id @default(cuid())
  userId       String          @map("user_id")
  amount       Int
  type         TransactionType
  description  String?
  referenceId  String?         @map("reference_id")
  balanceAfter Int             @map("balance_after")
  createdAt    DateTime        @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([referenceId, type])
  @@index([userId])
  @@index([referenceId])
  @@map("credit_transactions")
}

model CreditPackage {
  id        String  @id @default(cuid())
  name      String
  credits   Int
  price     Decimal @db.Decimal(10, 2)
  currency  String  @default("CNY")
  isActive  Boolean @default(true) @map("is_active")
  sortOrder Int     @default(0) @map("sort_order")

  @@map("credit_packages")
}

model Order {
  id            String      @id @default(cuid())
  userId        String      @map("user_id")
  packageId     String?     @map("package_id")
  amount        Decimal     @db.Decimal(10, 2)
  credits       Int
  currency      String      @default("CNY")
  status        OrderStatus @default(PENDING)
  paymentMethod String?     @map("payment_method")
  externalPayId String?     @map("external_pay_id")
  paidAt        DateTime?   @map("paid_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("orders")
}

// ==================== Generation ====================

model Generation {
  id             String    @id @default(cuid())
  userId         String    @map("user_id")
  type           JobType
  status         JobStatus @default(PENDING)
  provider       String
  model          String    @default("")
  prompt         String?
  negativePrompt String?   @map("negative_prompt")
  input          Json?
  output         Json?
  inputAssetId   String?   @map("input_asset_id")
  outputAssetId  String?   @map("output_asset_id")
  outputUrl      String?   @map("output_url")
  externalId     String?   @map("external_id")
  progress       Int       @default(0)
  creditsCost    Int?      @map("credits_cost")
  creditsUsed    Int?      @map("credits_used")
  errorMessage   String?   @map("error_message")
  errorMsg       String?   @map("error_msg")
  parameters     Json?
  metadata       Json?
  result         Json?
  createdAt      DateTime  @default(now()) @map("created_at")
  startedAt      DateTime? @map("started_at")
  completedAt    DateTime? @map("completed_at")

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  favorites   Favorite[]
  inputAsset  Asset?     @relation("JobInput", fields: [inputAssetId], references: [id])
  outputAsset Asset?     @relation("JobOutput", fields: [outputAssetId], references: [id])

  @@index([userId, type])
  @@index([userId, status])
  @@index([status])
  @@index([externalId])
  @@map("generations")
}

model Favorite {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  generationId String   @map("generation_id")
  createdAt    DateTime @default(now()) @map("created_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  generation Generation @relation(fields: [generationId], references: [id], onDelete: Cascade)

  @@unique([userId, generationId])
  @@map("favorites")
}

// ==================== Templates ====================

model Template {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String
  type        JobType?
  thumbnail   String?
  config      Json
  isPublic    Boolean  @default(true) @map("is_public")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@index([isPublic])
  @@map("templates")
}

// ==================== Assets ====================

model Asset {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  type      AssetType
  filename  String
  mimeType  String    @map("mime_type")
  size      BigInt
  ossKey    String    @map("oss_key")
  ossUrl    String    @map("oss_url")
  mediaId   String?   @map("media_id")
  duration  Float?
  width     Int?
  height    Int?
  metadata  Json?
  createdAt DateTime  @default(now()) @map("created_at")

  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  inputJobs  Generation[]   @relation("JobInput")
  outputJobs Generation[]   @relation("JobOutput")

  @@index([userId, type])
  @@index([mediaId])
  @@map("assets")
}

// ==================== Digital Human ====================

model Voice {
  id            String           @id @default(cuid())
  userId        String           @map("user_id")
  name          String
  voiceId       String           @default("") @map("voice_id")
  sampleUrl     String?          @map("sample_url")
  sampleAssetId String?          @map("sample_asset_id")
  status        VoiceCloneStatus @default(PENDING)
  provider      String           @default("qwen")
  errorMessage  String?          @map("error_message")
  isPublic      Boolean          @default(false) @map("is_public")
  language      String?          @default("zh-CN")
  gender        String?
  tags          Json             @default("[]")
  metadata      Json?
  createdAt     DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isPublic])
  @@map("voices")
}

model Material {
  id           String       @id @default(cuid())
  userId       String       @map("user_id")
  name         String
  type         MaterialType
  url          String
  thumbnailUrl String?      @map("thumbnail_url")
  size         Int          @default(0)
  mimeType     String       @default("application/octet-stream") @map("mime_type")
  isPublic     Boolean      @default(false) @map("is_public")
  category     String?
  metadata     Json?
  createdAt    DateTime     @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([isPublic, type])
  @@map("materials")
}

model DigitalHumanAvatar {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  name         String
  assetId      String   @map("asset_id")
  assetUrl     String?  @map("asset_url")
  detectResult Json?    @map("detect_result")
  isValid      Boolean  @default(false) @map("is_valid")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("digital_human_avatars")
}

model Script {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  title     String
  content   String
  tags      Json     @default("[]")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("scripts")
}

// ==================== Compose ====================

model ComposeProject {
  id        String        @id @default(cuid())
  userId    String        @map("user_id")
  name      String
  config    Json
  status    ComposeStatus @default(DRAFT)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs ComposeJob[]

  @@index([userId])
  @@map("compose_projects")
}

model ComposeJob {
  id            String         @id @default(cuid())
  projectId     String         @map("project_id")
  externalJobId String?        @map("external_job_id")
  status        JobStatus      @default(PENDING)
  progress      Int            @default(0)
  outputAssets  Json?
  creditsCost   Int?           @map("credits_cost")
  errorMessage  String?        @map("error_message")
  createdAt     DateTime       @default(now()) @map("created_at")
  completedAt   DateTime?      @map("completed_at")

  project ComposeProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([externalJobId])
  @@map("compose_jobs")
}

// ==================== Admin Config ====================

model SystemConfig {
  id    String @id @default(cuid())
  key   String @unique
  value Json

  @@map("system_configs")
}

model ProviderConfig {
  id          String   @id @default(cuid())
  name        String
  provider    String   @unique
  apiKey      String   @default("") @map("api_key")
  apiEndpoint String?  @map("api_endpoint")
  isEnabled   Boolean  @default(true) @map("is_enabled")
  rateLimit   Int?     @map("rate_limit")
  config      Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("provider_configs")
}

model ModelConfig {
  id           String  @id @default(cuid())
  provider     String
  modelId      String  @map("model_id")
  displayName  String  @map("display_name")
  type         JobType
  creditCost   Int     @map("credit_cost")
  costUnit     String  @default("per_image") @map("cost_unit")
  isActive     Boolean @default(true) @map("is_active")
  capabilities Json?
  maxDuration  Int?    @map("max_duration")
  sortOrder    Int     @default(0) @map("sort_order")

  @@unique([provider, modelId])
  @@map("model_configs")
}

// ==================== Audit ====================

model AuditLog {
  id          String   @id @default(cuid())
  performerId String   @map("performer_id")
  targetId    String?  @map("target_id")
  action      String
  details     Json?
  createdAt   DateTime @default(now()) @map("created_at")

  performer User  @relation("performer", fields: [performerId], references: [id], onDelete: Cascade)
  target    User? @relation("target", fields: [targetId], references: [id], onDelete: SetNull)

  @@index([performerId])
  @@index([targetId])
  @@index([action])
  @@map("audit_logs")
}
