generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum GenerationType {
  IMAGE
  VIDEO
  VOICE_CLONE
  TTS
  DIGITAL_HUMAN
  DIGITAL_HUMAN_VIDEO
  VIDEO_EDIT
  BATCH_COMPOSE
  TEXT_TO_IMAGE
  IMAGE_TO_IMAGE
  TEXT_TO_VIDEO
  IMAGE_TO_VIDEO
  STYLE_COPY
  TEXT_EDIT
  HANDHELD_PRODUCT
  DH_BATCH_V2
  MULTI_FUSION
  VIRTUAL_TRYON
  INPAINT
  IMAGE_EDIT
  STORYBOARD
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum MaterialType {
  IMAGE
  VIDEO
  AUDIO
  TEMPLATE
  BACKGROUND
  STICKER
  AVATAR
}

enum TransactionType {
  PURCHASE
  USAGE
  REFUND
  ADMIN_ADJUSTMENT
  BONUS
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  displayName   String    @map("display_name")
  avatar        String?
  role          UserRole  @default(USER)
  status        UserStatus @default(ACTIVE)
  creditBalance Int       @default(0) @map("credit_balance")
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  oauthAccounts      OAuthAccount[]
  generations        Generation[]
  voices             Voice[]
  materials          Material[]
  scripts            Script[]
  creditTransactions CreditTransaction[]
  orders             Order[]
  favorites          Favorite[]
  auditLogsPerformed AuditLog[] @relation("performer")
  auditLogsTargeted  AuditLog[] @relation("target")

  @@map("users")
}

model OAuthAccount {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  provider   String
  providerId String   @map("provider_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@map("oauth_accounts")
}

model Generation {
  id          String         @id @default(cuid())
  userId      String         @map("user_id")
  type        GenerationType
  status      JobStatus      @default(PENDING)
  provider    String
  input       Json
  output      Json?
  creditsUsed Int            @default(0) @map("credits_used")
  externalId  String?        @map("external_id")
  errorMsg    String?        @map("error_msg")
  createdAt   DateTime       @default(now()) @map("created_at")
  completedAt DateTime?      @map("completed_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  favorites Favorite[]

  @@index([userId, type])
  @@index([status])
  @@index([externalId])
  @@map("generations")
}

model Voice {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  name      String
  voiceId   String   @map("voice_id")
  provider  String   @default("aliyun-cosyvoice")
  sampleUrl String   @map("sample_url")
  status    String   @default("PENDING")
  isPublic  Boolean  @default(false) @map("is_public")
  metadata  Json?    @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("voices")
}

model Material {
  id           String       @id @default(cuid())
  userId       String       @map("user_id")
  type         MaterialType
  name         String
  url          String
  thumbnailUrl String?      @map("thumbnail_url")
  size         Int          @default(0)
  mimeType     String       @default("application/octet-stream") @map("mime_type")
  isPublic     Boolean      @default(false) @map("is_public")
  metadata     Json?        @default("{}")
  createdAt    DateTime     @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@map("materials")
}

model Template {
  id        String   @id @default(cuid())
  name      String
  category  String
  thumbnail String?
  config    Json
  isPublic  Boolean  @default(true) @map("is_public")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("templates")
}

model Script {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  title     String
  content   String
  tags      String[] @default([])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("scripts")
}

model CreditTransaction {
  id           String          @id @default(cuid())
  userId       String          @map("user_id")
  amount       Int
  type         TransactionType
  description  String
  referenceId  String?         @map("reference_id")
  balanceAfter Int             @map("balance_after")
  createdAt    DateTime        @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("credit_transactions")
}

model Order {
  id            String      @id @default(cuid())
  userId        String      @map("user_id")
  amount        Int
  credits       Int
  status        OrderStatus @default(PENDING)
  paymentMethod String?     @map("payment_method")
  paymentId     String?     @map("payment_id")
  paidAt        DateTime?   @map("paid_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("orders")
}

model Favorite {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  generationId String   @map("generation_id")
  createdAt    DateTime @default(now()) @map("created_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  generation Generation @relation(fields: [generationId], references: [id], onDelete: Cascade)

  @@unique([userId, generationId])
  @@map("favorites")
}

model SystemConfig {
  id    String @id @default(cuid())
  key   String @unique
  value Json

  @@map("system_configs")
}

model ProviderConfig {
  id         String   @id @default(cuid())
  providerId String   @unique @map("provider_id")
  name       String
  isEnabled  Boolean  @default(true) @map("is_enabled")
  config     Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("provider_configs")
}

model AuditLog {
  id          String   @id @default(cuid())
  performerId String   @map("performer_id")
  targetId    String?  @map("target_id")
  action      String
  details     Json?    @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  performer User  @relation("performer", fields: [performerId], references: [id])
  target    User? @relation("target", fields: [targetId], references: [id])

  @@index([performerId])
  @@index([action])
  @@map("audit_logs")
}
